<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.univr.telemedicina.presentation.controller.AuditLogsController"
      spacing="20" styleClass="modal-container" prefWidth="650" prefHeight="480"
      style="-fx-background-color: -color-bg-base; -fx-padding: 24;">

    <VBox spacing="6">
        <Label text="Audit Logs" styleClass="modal-title"/>
        <Label text="Log of all medical database operations performed by you" styleClass="modal-subtitle"/>
    </VBox>

    <TableView fx:id="logsTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="timestampCol" text="Timestamp" prefWidth="150"/>
            <TableColumn fx:id="patientCol" text="Patient" prefWidth="180"/>
            <TableColumn fx:id="operationCol" text="Operation" prefWidth="300"/>
        </columns>
        <placeholder>
            <Label text="No logs recorded." style="-fx-text-fill: -color-border;"/>
        </placeholder>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="12">
        <Button text="Close" onAction="#onClose" styleClass="button-secondary" style="-fx-padding: 8 16;"/>
    </HBox>
</VBox>
