<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.univr.telemedicina.presentation.controller.GlucoseChartController"
      style="-fx-background-color: -color-bg-base;">

    <!-- Sidebar -->
    <VBox styleClass="sidebar" spacing="2">
        <Label text="⚕️ Doctor" styleClass="sidebar-title"/>
        <Separator/>
        <Button text="📊  Dashboard" onAction="#onBack" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="📈  Glucose Chart" styleClass="sidebar-button,sidebar-button-active" maxWidth="1.7976931348623157E308"/>
        <VBox VBox.vgrow="ALWAYS"/>
        <Separator/>
        <Button text="🚪  Logout" onAction="#onLogout" styleClass="sidebar-button" style="-fx-text-fill: #f38ba8;" maxWidth="1.7976931348623157E308"/>
    </VBox>

    <!-- Main Content -->
    <VBox HBox.hgrow="ALWAYS" spacing="20" style="-fx-padding: 30;">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Button text="← Back" onAction="#onBack" styleClass="button-secondary"/>
            <Label fx:id="titleLabel" text="Glucose Trend" styleClass="title"/>
        </HBox>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Period:" styleClass="field-label"/>
            <ComboBox fx:id="periodCombo" promptText="Select period"/>
            <Button text="Refresh" onAction="#onRefresh" styleClass="button-primary"/>
        </HBox>

        <!-- Summary Table (synthetic data) -->
        <Label text="Weekly / Monthly Averages" styleClass="section-title"/>
        <TableView fx:id="summaryTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="periodCol" text="Period" prefWidth="180"/>
                <TableColumn fx:id="avgBeforeCol" text="Avg Before Meal" prefWidth="140"/>
                <TableColumn fx:id="avgAfterCol" text="Avg After Meal" prefWidth="140"/>
                <TableColumn fx:id="countCol" text="Measurements" prefWidth="120"/>
                <TableColumn fx:id="alertsCol" text="Abnormal" prefWidth="100"/>
            </columns>
            <placeholder>
                <Label text="No data available." style="-fx-text-fill: -color-border;"/>
            </placeholder>
        </TableView>
    </VBox>
</HBox>
