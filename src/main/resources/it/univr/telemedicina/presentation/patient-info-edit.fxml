<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.univr.telemedicina.presentation.controller.PatientInfoEditController"
      style="-fx-background-color: #1e1e2e; -fx-padding: 30px;" spacing="20" prefWidth="550">
      
    <Label fx:id="titleLabel" text="Edit Patient Medical Information" styleClass="title"/>
    <Label fx:id="patientLabel" text="" styleClass="subtitle"/>

    <VBox styleClass="card" spacing="16" maxWidth="500">
        <VBox spacing="6">
            <Label text="RISK FACTORS" styleClass="field-label"/>
            <TextArea fx:id="riskFactorsArea" promptText="e.g. smoker, ex-smoker, obesity, alcohol dependency..." prefRowCount="3"/>
        </VBox>

        <VBox spacing="6">
            <Label text="PAST PATHOLOGIES" styleClass="field-label"/>
            <TextArea fx:id="pastPathologiesArea" promptText="e.g. cardiovascular disease, previous surgeries..." prefRowCount="3"/>
        </VBox>

        <VBox spacing="6">
            <Label text="COMORBIDITIES" styleClass="field-label"/>
            <TextArea fx:id="comorbiditiesArea" promptText="e.g. hypertension, renal failure..." prefRowCount="3"/>
        </VBox>

        <Label fx:id="feedbackLabel" text="" managed="false" visible="false"/>

        <HBox spacing="12">
            <Button text="Save Changes" onAction="#onSave" styleClass="button-primary"/>
            <Button text="Reset" onAction="#onReset" styleClass="button-secondary"/>
            <Button text="Close" onAction="#onClose" styleClass="button-secondary"/>
        </HBox>
    </VBox>
</VBox>
