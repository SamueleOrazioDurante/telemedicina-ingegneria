<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.univr.telemedicina.presentation.controller.DrugIntakeEntryController"
      style="-fx-background-color: #1e1e2e;">

    <!-- Sidebar -->
    <VBox styleClass="sidebar" spacing="2">
        <Label text="🩺 Patient" styleClass="sidebar-title"/>
        <Separator/>
        <Button text="📊  Dashboard" onAction="#onDashboard" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="🩸  Record Glucose" onAction="#onRecordGlucose" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="📋  Glucose History" onAction="#onGlucoseHistory" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="💊  Record Drug Intake" onAction="#onRecordDrugIntake" styleClass="sidebar-button,sidebar-button-active" maxWidth="1.7976931348623157E308"/>
        <Button text="🤒  Report Condition" onAction="#onReportCondition" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="📜  My Therapies" onAction="#onMyTherapies" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="✉️  Email Doctor" onAction="#onEmailDoctor" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <VBox VBox.vgrow="ALWAYS"/>
        <Separator/>
        <Button text="🚪  Logout" onAction="#onLogout" styleClass="sidebar-button" style="-fx-text-fill: #f38ba8;" maxWidth="1.7976931348623157E308"/>
    </VBox>

    <!-- Main Content -->
    <VBox HBox.hgrow="ALWAYS" spacing="20" style="-fx-padding: 30;">
        <Label text="Record Drug Intake" styleClass="title"/>
        <Label text="Log the medications you have taken as prescribed." styleClass="subtitle"/>

        <VBox styleClass="card" spacing="16" maxWidth="500">
            <VBox spacing="6">
                <Label text="SELECT ACTIVE THERAPY" styleClass="field-label"/>
                <ComboBox fx:id="therapyCombo" maxWidth="1.7976931348623157E308" promptText="Select therapy..."/>
            </VBox>

            <VBox spacing="6">
                <Label text="DRUG NAME" styleClass="field-label"/>
                <TextField fx:id="drugNameField" editable="false" style="-fx-opacity: 0.7;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="QUANTITY TAKEN" styleClass="field-label"/>
                <TextField fx:id="quantityField" promptText="e.g. 500mg, 1 pill"/>
            </VBox>

            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="DATE" styleClass="field-label"/>
                    <DatePicker fx:id="datePicker" maxWidth="1.7976931348623157E308"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="TIME (HH:MM)" styleClass="field-label"/>
                    <TextField fx:id="timeField" promptText="e.g. 13:00"/>
                </VBox>
            </HBox>

            <Label fx:id="feedbackLabel" text="" managed="false" visible="false"/>

            <HBox spacing="12">
                <Button text="Save Intake" onAction="#onSave" styleClass="button-success"/>
                <Button text="Clear" onAction="#onClear" styleClass="button-secondary"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
