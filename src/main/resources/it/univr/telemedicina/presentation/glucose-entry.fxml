<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.univr.telemedicina.presentation.controller.GlucoseEntryController"
      style="-fx-background-color: -color-bg-base; -fx-padding: 30px;" spacing="20" prefWidth="500">
      
    <Label text="Record Blood Glucose" styleClass="title"/>
    <Label text="Enter your blood glucose reading before or after a meal." styleClass="subtitle"/>

    <VBox styleClass="card" spacing="16" maxWidth="450">
        <VBox spacing="6">
            <Label text="GLUCOSE VALUE (mg/dL)" styleClass="field-label"/>
            <TextField fx:id="glucoseValueField" promptText="e.g. 120"/>
        </VBox>

        <VBox spacing="6">
            <Label text="TIME SLOT" styleClass="field-label"/>
            <ComboBox fx:id="timeSlotCombo" maxWidth="1.7976931348623157E308" promptText="Select time slot"/>
        </VBox>

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="DATE" styleClass="field-label"/>
                <DatePicker fx:id="datePicker" maxWidth="1.7976931348623157E308"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="TIME (HH:MM)" styleClass="field-label"/>
                <TextField fx:id="timeField" promptText="e.g. 08:30"/>
            </VBox>
        </HBox>

        <Label fx:id="feedbackLabel" text="" managed="false" visible="false"/>

        <HBox spacing="12">
            <Button text="Save" onAction="#onSave" styleClass="button-primary"/>
            <Button text="Clear" onAction="#onClear" styleClass="button-secondary"/>
            <Button text="Close" onAction="#onClose" styleClass="button-secondary"/>
        </HBox>
    </VBox>
</VBox>
