<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.univr.telemedicina.presentation.controller.PatientTherapiesController"
      style="-fx-background-color: -color-bg-base;">

    <!-- Sidebar -->
    <VBox styleClass="sidebar" spacing="2">
        <Label text="🩺 Patient" styleClass="sidebar-title"/>
        <Separator/>
        <Button text="📊  Dashboard" onAction="#onDashboard" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="🩸  Record Glucose" onAction="#onRecordGlucose" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="📋  Glucose History" onAction="#onGlucoseHistory" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="💊  Record Drug Intake" onAction="#onRecordDrugIntake" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="🤒  Report Condition" onAction="#onReportCondition" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="📜  My Therapies" onAction="#onMyTherapies" styleClass="sidebar-button,sidebar-button-active" maxWidth="1.7976931348623157E308"/>
        <Button text="✉️  Email Doctor" onAction="#onEmailDoctor" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <VBox VBox.vgrow="ALWAYS"/>
        <Separator/>
        <Button text="🚪  Logout" onAction="#onLogout" styleClass="sidebar-button" style="-fx-text-fill: #f38ba8;" maxWidth="1.7976931348623157E308"/>
    </VBox>

    <!-- Main Content -->
    <VBox HBox.hgrow="ALWAYS" spacing="20" style="-fx-padding: 30;">
        <Label text="My Prescribed Therapies" styleClass="title"/>
        <Label text="View all current and past therapies prescribed by your doctor." styleClass="subtitle"/>

        <TableView fx:id="therapyTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="drugCol" text="Drug" prefWidth="140"/>
                <TableColumn fx:id="dailyCol" text="Daily Intakes" prefWidth="100"/>
                <TableColumn fx:id="quantityCol" text="Quantity" prefWidth="100"/>
                <TableColumn fx:id="directionsCol" text="Directions" prefWidth="160"/>
                <TableColumn fx:id="startCol" text="Start Date" prefWidth="100"/>
                <TableColumn fx:id="endCol" text="End Date" prefWidth="100"/>
                <TableColumn fx:id="statusCol" text="Status" prefWidth="90"/>
            </columns>
            <placeholder>
                <Label text="No therapies found." style="-fx-text-fill: -color-border;"/>
            </placeholder>
        </TableView>
    </VBox>
</HBox>
