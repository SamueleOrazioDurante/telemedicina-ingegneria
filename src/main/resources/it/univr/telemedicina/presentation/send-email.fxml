<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.univr.telemedicina.presentation.controller.SendEmailController"
      style="-fx-background-color: #1e1e2e;">

    <!-- Sidebar -->
    <VBox styleClass="sidebar" spacing="2">
        <Label text="🩺 Patient" styleClass="sidebar-title"/>
        <Separator/>
        <Button text="📊  Dashboard" onAction="#onDashboard" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="🩸  Record Glucose" onAction="#onRecordGlucose" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="📋  Glucose History" onAction="#onGlucoseHistory" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="💊  Record Drug Intake" onAction="#onRecordDrugIntake" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="🤒  Report Condition" onAction="#onReportCondition" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="📜  My Therapies" onAction="#onMyTherapies" styleClass="sidebar-button" maxWidth="1.7976931348623157E308"/>
        <Button text="✉️  Email Doctor" onAction="#onEmailDoctor" styleClass="sidebar-button,sidebar-button-active" maxWidth="1.7976931348623157E308"/>
        <VBox VBox.vgrow="ALWAYS"/>
        <Separator/>
        <Button text="🚪  Logout" onAction="#onLogout" styleClass="sidebar-button" style="-fx-text-fill: #f38ba8;" maxWidth="1.7976931348623157E308"/>
    </VBox>

    <!-- Main Content -->
    <VBox HBox.hgrow="ALWAYS" spacing="20" style="-fx-padding: 30;">
        <Label text="Send Message to Doctor" styleClass="title"/>
        <Label text="Send a message to your reference doctor for questions and requests." styleClass="subtitle"/>

        <VBox styleClass="card" spacing="16" maxWidth="600">
            <VBox spacing="6">
                <Label text="RECIPIENT" styleClass="field-label"/>
                <TextField fx:id="recipientField" editable="false" style="-fx-opacity: 0.7;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="SUBJECT" styleClass="field-label"/>
                <TextField fx:id="subjectField" promptText="Subject of your message"/>
            </VBox>

            <VBox spacing="6">
                <Label text="MESSAGE" styleClass="field-label"/>
                <TextArea fx:id="messageArea" promptText="Type your message here..." prefRowCount="8"/>
            </VBox>

            <Label fx:id="feedbackLabel" text="" managed="false" visible="false"/>

            <HBox spacing="12">
                <Button text="Send Message" onAction="#onSend" styleClass="button-primary"/>
                <Button text="Clear" onAction="#onClear" styleClass="button-secondary"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
